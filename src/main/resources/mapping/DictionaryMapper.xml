<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.publicordercasemanagementsystem.mapper.DictionaryMapper">

    <resultMap id="CaseTypeResult" type="com.example.publicordercasemanagementsystem.pojo.DictCaseType">
        <id column="code" property="code" />
        <result column="name" property="name" />
        <result column="sort_order" property="sortOrder" />
        <result column="is_active" property="isActive" />
    </resultMap>

    <select id="findActiveCaseTypes" resultMap="CaseTypeResult">
        select code, name, sort_order, is_active
        from dict_case_types
        where is_active = 1
        order by sort_order asc, code asc
    </select>

</mapper>

